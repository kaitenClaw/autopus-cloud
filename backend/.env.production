# Autopus Production Environment Configuration
# Deploy to: ~/ocaas-project/backend/.env.production

# Database - Fixed connection string for Docker network
DATABASE_URL="postgresql://ocaas:ocaas_password@postgres:5432/ocaas?schema=public"

# JWT Secrets (keep existing)
JWT_ACCESS_SECRET="038945338091f27a1b62c59a1c2844ce17a3130007c23702d8e7f8e4afe9b00c"
JWT_REFRESH_SECRET="e939a23d1b80dd7167825df9a979b4d4df9b20c74934c2adfc6a7a6b68dd03f0"

# Port - Keep internal port 3000, mapped to 4000 externally
PORT=3000

# CORS - All Autopus domains
ALLOWED_ORIGINS="https://autopus.cloud,https://www.autopus.cloud,https://dashboard.autopus.cloud,https://hub.autopus.cloud,https://api.autopus.cloud,https://settings.autopus.cloud,https://*.autopus.cloud"

# Admin users
ADMIN_EMAILS="altoncheng.research@gmail.com,kaiten.autopus@gmail.com"

# Google OAuth (to be configured)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LiteLLM Proxy
LITELLM_MASTER_KEY="vertex-proxy"
LITELLM_PROXY_URL="http://litellm:4000"

# Environment
NODE_ENV="production"

# Stripe (to be configured)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_FREE=""
STRIPE_PRICE_ID_LAUNCH=""
STRIPE_PRICE_ID_PRO=""

# Email (to be configured)
