# Autopus Cloud - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"
DB_USER=ocaas
DB_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE
DB_NAME=ocaas

# JWT Secrets - Generate strong random values:
# openssl rand -base64 64
JWT_ACCESS_SECRET="tr6Jhwu0Wfw/PVHrhBrY866kfP1d2SErJsaKQlQJVXBkBqMiufNWznzfaPC2brUFaGQSRFL2Ed8WesVSweYRpg=="
JWT_REFRESH_SECRET="ECZcG1oQc+b9Nt3FOX6WIBLnbKcgIvfXGuQoFPLysS7QADAdX0V3BgewIJRcf5Opexj31IhaaeLa9oIG5YaWeA=="

# Server
PORT=3000
NODE_ENV="production"

# CORS - Comma-separated list of allowed origins
# Include ALL subdomains used by the app
ALLOWED_ORIGINS="https://autopus.cloud,https://www.autopus.cloud,https://dashboard.autopus.cloud,https://hub.autopus.cloud,https://api.autopus.cloud,https://settings.autopus.cloud"

# Admin emails - Comma-separated
ADMIN_EMAILS="admin@yourdomain.com"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# LiteLLM Proxy
LITELLM_MASTER_KEY="your-litellm-master-key"

# Vultr API (for cloud deploy)
VULTR_API_KEY="your-vultr-api-key"

# Stripe (for billing)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (for notifications)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
