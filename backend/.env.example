# Autopus Cloud - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# JWT Secrets - Generate strong random values:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="GENERATE_A_SECURE_64_CHAR_HEX_STRING"
JWT_REFRESH_SECRET="GENERATE_ANOTHER_SECURE_64_CHAR_HEX_STRING"

# Server
PORT=3000
NODE_ENV="production"

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS="https://autopus.cloud,https://www.autopus.cloud,https://dashboard.autopus.cloud,https://hub.autopus.cloud"

# Admin emails - Comma-separated
ADMIN_EMAILS="admin@yourdomain.com"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# LiteLLM Proxy
LITELLM_MASTER_KEY="your-litellm-master-key"

# Vultr API (for cloud deploy)
VULTR_API_KEY="your-vultr-api-key"

# Stripe (for billing)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (for notifications)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
